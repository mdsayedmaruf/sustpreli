# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional overrides
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App attribution (shown on OpenRouter)
APP_URL=http://localhost:5173
APP_TITLE=Hackathon Chatbot

# System prompt
SYSTEM_PROMPT=You are a helpful, friendly assistant. Answer clearly and concisely.

# CORS: comma-separated origins, or * for all
CORS_ORIGINS=*

# Optional: Postgres (e.g. Neon) for saving chat history.
# Leave blank to run without persistence.
# Example: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# QueueStorm Investigator — environment variables.
# The service runs fully WITHOUT any of these set (deterministic, LLM-free path).

# CORS: comma-separated origins, or * for all.
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Optional LLM polishing of prose fields only (OFF by default).
# The structured decision (verdict, case_type, department, severity) is always
# deterministic. Enabling this never changes enum-exactness or the 30s budget.
# ---------------------------------------------------------------------------
# USE_LLM=false
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_TIMEOUT_SECONDS=10
